{
  "manifest_version": 3,
  "name": "CITD Grade Checker",
  "version": "1.4",
  "permissions": [
    "notifications",
    "storage",
    "alarms",
    "offscreen"
  ],
  "host_permissions": [
    "https://student.citd.edu.vn/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "CITD Grade Checker"
  }
}